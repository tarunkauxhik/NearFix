# ─── Application ──────────────────────────────────────────────────────────────
VITE_APP_NAME=NearFix
VITE_PUBLIC_URL=http://localhost:5173
VITE_API_URL=http://localhost:5173/api

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
# Vite dev server (local)
PORT=5173

# Production Node listener (vite-plugin-api-routes reads SERVER_*).
# `npm start` maps PORT → SERVER_PORT when SERVER_PORT is unset (Railway/Render).
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# Optional: restrict dev HMR / CORS (comma-separated origins). See README.
# FRONTEND_DOMAIN=https://your-app.onrender.com
# ALLOWED_ORIGINS=https://a.com,https://b.com
# VITE_PARENT_ORIGIN=https://parent.example.com

# OpenStreetMap Nominatim (server-side geocode proxy). Set a contact email per
# https://operations.osmfoundation.org/policies/nominatim/
# NOMINATIM_EMAIL=you@example.com
# NOMINATIM_USER_AGENT=NearFix/1.0 (https://yoursite.com; contact you@example.com)

# ─── Database (Postgres / Neon) ───────────────────────────────────────────────
# Get a free Postgres database from https://neon.tech and paste its connection
# string here. Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/nearfix

# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Create an application at https://dashboard.clerk.com and paste your keys.
# The publishable key is exposed to the browser (must start with VITE_).
# The secret key is server-only and must NEVER be committed.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Optional admin bootstrap (comma-separated)
# Use either Clerk private_metadata.role = "admin" or one of the env-based
# bootstrap options below for your own account during setup.
# ADMIN_EMAILS accepts any email attached to your Clerk user.
# ADMIN_USERNAMES accepts Clerk usernames (for example: tarunkaushik).
# ADMIN_USER_IDS accepts Clerk user ids like user_123abc.
ADMIN_EMAILS=
ADMIN_USERNAMES=
ADMIN_USER_IDS=
